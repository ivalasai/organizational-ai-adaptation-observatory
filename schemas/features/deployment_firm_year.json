{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FirmYearDeploymentFeatures",
  "description": "Firm-year organizational deployment signal features",
  "type": "object",
  "required": ["firm_id", "year", "source"],
  "properties": {
    "firm_id": { "type": "string", "pattern": "^OAA-" },
    "year": { "type": "integer", "minimum": 1990 },
    "source": { "type": "string" },
    "product_launch_count": { "type": "integer", "minimum": 0 },
    "api_launch_count": { "type": "integer", "minimum": 0 },
    "feature_release_count": { "type": "integer", "minimum": 0 },
    "documentation_update_count": { "type": "integer", "minimum": 0 },
    "total_deployment_events": { "type": "integer", "minimum": 0 }
  }
}
