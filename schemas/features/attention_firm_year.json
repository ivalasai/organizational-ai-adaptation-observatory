{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FirmYearAttentionFeatures",
  "description": "Firm-year organizational attention signal features",
  "type": "object",
  "required": ["firm_id", "year", "source"],
  "properties": {
    "firm_id": { "type": "string", "pattern": "^OAA-" },
    "year": { "type": "integer", "minimum": 1990 },
    "source": { "type": "string" },
    "document_count": { "type": "integer", "minimum": 0 },
    "ai_mention_count": { "type": "integer", "minimum": 0 },
    "ai_mention_share": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "ai_token_count": { "type": ["integer", "null"], "minimum": 0 }
  }
}
