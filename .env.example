# Copy to .env and fill in credentials. Never commit .env.

# WRDS (Wharton Research Data Services)
WRDS_USERNAME=
WRDS_PASSWORD=

# SEC EDGAR (optional; public API often works without credentials)
SEC_USER_AGENT=YourName your.email@example.com

# Optional commercial data providers
# REFINITIV_API_KEY=
# CRUNCHBASE_API_KEY=
# LINKEDIN_API_KEY=

# Runtime paths (override defaults in configs/default.toml)
# OAA_DATA_ROOT=/path/to/data
# OAA_OUTPUT_ROOT=/path/to/output
# OAA_LOG_LEVEL=INFO
